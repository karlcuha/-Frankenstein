:root {
  --page-bg: #252525;
  --bot-bg: #f4f4f4;
  --user-bg: #ffc85a;
  --text: #090909;
  --muted: #a7a7a7;
  --input-bg: #f7f7f7;
  --active: #ffbd45;
  --max-chat-width: 700px;
}

* {
  box-sizing: border-box;
}

html,
body {
  min-height: 100%;
}

body {
  margin: 0;
  background: var(--page-bg);
  color: var(--text);
  font-family: Arial, Helvetica, sans-serif;
}

button,
input {
  font: inherit;
}

button {
  border: 0;
}

.chat {
  width: min(100%, var(--max-chat-width));
  height: 100svh;
  min-height: 520px;
  margin: 0 auto;
  padding: 18px clamp(18px, 4vw, 36px) clamp(18px, 4vw, 28px);
  display: flex;
  flex-direction: column;
  background: var(--page-bg);
  overflow: hidden;
}

.chat__title {
  margin: 0;
  flex: 0 0 auto;
  color: #ffffff;
  font-size: clamp(32px, 7vw, 54px);
  line-height: 1.05;
  font-weight: 800;
  text-align: center;
  letter-spacing: 0.01em;
}

.chat__messages {
  flex: 1 1 auto;
  min-height: 0;
  padding: clamp(18px, 3vw, 28px) 0 clamp(12px, 2vw, 20px);
  display: flex;
  flex-direction: column-reverse;
  gap: 18px;
  overflow-y: auto;
  overscroll-behavior: contain;
  scrollbar-width: thin;
  scrollbar-color: rgba(255, 255, 255, 0.28) transparent;
}

.chat__messages::-webkit-scrollbar {
  width: 8px;
}

.chat__messages::-webkit-scrollbar-track {
  background: transparent;
}

.chat__messages::-webkit-scrollbar-thumb {
  background: rgba(255, 255, 255, 0.28);
  border-radius: 999px;
}

.message {
  width: 100%;
  display: flex;
  align-items: flex-start;
  gap: 14px;
  flex: 0 0 auto;
}

.message__avatar {
  width: clamp(46px, 9vw, 56px);
  height: clamp(46px, 9vw, 56px);
  flex: 0 0 clamp(46px, 9vw, 56px);
  border-radius: 50%;
  object-fit: cover;
  background: #ffffff;
}

.message__bubble {
  width: fit-content;
  max-width: min(78%, 520px);
  padding: 14px 18px;
  border-radius: 22px;
  color: var(--text);
  font-size: clamp(15px, 2.4vw, 18px);
  line-height: 1.22;
  overflow-wrap: anywhere;
  word-break: normal;
  box-shadow: 0 1px 0 rgba(0, 0, 0, 0.02);
}

.message--bot .message__bubble {
  background: var(--bot-bg);
  border-top-left-radius: 20px;
}

.message--user .message__bubble {
  background: var(--user-bg);
  border-top-left-radius: 20px;
}

.message--typing .message__bubble {
  min-width: 82px;
  min-height: 44px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 12px 18px;
}

.typing-dots {
  display: inline-flex;
  align-items: center;
  gap: 7px;
}

.typing-dots span {
  width: 7px;
  height: 7px;
  border-radius: 50%;
  background: currentColor;
  opacity: 0.35;
  animation: typing 1s infinite ease-in-out;
}

.typing-dots span:nth-child(2) {
  animation-delay: 0.15s;
}

.typing-dots span:nth-child(3) {
  animation-delay: 0.3s;
}

@keyframes typing {
  0%, 80%, 100% {
    transform: translateY(0);
    opacity: 0.35;
  }
  40% {
    transform: translateY(-4px);
    opacity: 1;
  }
}

.chat__form {
  flex: 0 0 auto;
  height: 56px;
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 6px 8px 6px 20px;
  background: var(--input-bg);
  border-radius: 999px;
}

.chat__input {
  width: 100%;
  min-width: 0;
  height: 100%;
  border: 0;
  outline: 0;
  background: transparent;
  color: var(--text);
  font-size: 16px;
  line-height: 1;
}

.chat__input::placeholder {
  color: rgba(0, 0, 0, 0.45);
}


.chat__send {
  width: 44px;
  height: 44px;
  flex: 0 0 44px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: transparent;
  color: var(--muted);
  cursor: not-allowed;
  opacity: 1;
  appearance: none;
  -webkit-appearance: none;
  transition: color 0.2s ease, transform 0.2s ease;
}

.chat__send:disabled {
  color: var(--muted);
  cursor: not-allowed;
  opacity: 1;
}

.chat__send:not(:disabled) {
  color: var(--active);
  cursor: pointer;
}

.chat__send:not(:disabled):hover {
  transform: translateY(-1px);
}

.chat__send:not(:disabled):active {
  transform: translateY(0);
}

.chat__send-icon {
  width: 24px;
  height: 24px;
  display: block;
  color: currentColor;
}

.visually-hidden {
  position: absolute;
  width: 1px;
  height: 1px;
  padding: 0;
  margin: -1px;
  overflow: hidden;
  clip: rect(0, 0, 0, 0);
  white-space: nowrap;
  border: 0;
}

@media (max-width: 480px) {
  .chat {
    min-height: 100svh;
    padding-inline: 22px;
  }

  .chat__messages {
    gap: 16px;
  }

  .message {
    gap: 12px;
  }

  .message__bubble {
    max-width: calc(100% - 64px);
    padding: 13px 16px;
    border-radius: 20px;
  }

  .chat__form {
    height: 50px;
    padding-left: 18px;
  }

  .chat__send {
    width: 40px;
    height: 40px;
    flex-basis: 40px;
  }
}

@media (min-width: 900px) {
  body {
    display: flex;
    justify-content: center;
  }
}

